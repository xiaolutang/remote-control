# ===== Remote Control 环境变量配置 =====
# 复制此文件为 .env 并填写配置: cp .env.example .env

# ----- 必填 -----
# JWT 签名密钥（必填，不允许留空）
# 生成方式: openssl rand -hex 32
JWT_SECRET=

# Redis 密码（必填）
REDIS_PASSWORD=

# ----- LLM 配置（Agent 功能必需） -----
# LLM API 密钥（为空时 Agent 功能返回 503）
LLM_API_KEY=
# LLM API 地址（OpenAI-compatible）
LLM_BASE_URL=
# 模型名称
LLM_MODEL=

# ----- CORS 跨域配置 -----
# 允许的来源域名（逗号分隔），禁止使用 *
# 示例: https://localhost,https://your-domain.com
CORS_ORIGINS=

# ----- 可选配置 -----
# JWT 过期时间（小时，默认 168 即 7 天）
JWT_EXPIRY_HOURS=168

# 日志级别
LOG_LEVEL=INFO

# Server 直接暴露端口（默认 8880）
RC_DIRECT_PORT=8880

# ----- Agent 独立部署（可选） -----
# 启用方式: docker compose --profile standalone-agent up -d agent
# AGENT_USERNAME=
# AGENT_PASSWORD=
# AGENT_TOKEN=

# ----- 生产环境（Traefik 网关） -----
# 以下变量仅在 docker-compose.yml（生产模式）中使用
# 自包含开发模式（docker-compose.dev.yml）不需要这些变量

# Traefik 路由规则（生产环境）
# 替换为你的域名，例如: Host(`your-domain.com`) && PathPrefix(`/rc/`)
# TRAEFIK_ROUTER_RULE=Host(`localhost`) && PathPrefix(`/rc/`)

# TLS 代理认证令牌（生产环境，Traefik → Server 通信校验）
# TRUSTED_PROXY_TLS_TOKEN=
